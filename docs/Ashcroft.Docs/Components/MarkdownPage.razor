@page "/{*Path}"
@using System.Reflection
@inject IPageResolver Resolver

@* Catch-all page: IPageResolver collapses discover -> parse -> render into one
   call, so this component only decides what the resolved page looks like. *@

@if (_page is null)
{
    <PageTitle>Not found · Ashcroft</PageTitle>
    <main class="mx-auto max-w-5xl px-5 py-28 sm:px-10 lg:px-14">
        <h1 class="m-0 text-4xl font-semibold tracking-tight">Page not found</h1>
        <p class="mt-4 text-base-500"><a class="text-primary-600 hover:text-primary-800" href="/">Back to the docs</a></p>
    </main>
}
else
{
    <PageTitle>@_title · social cards from a tiny C# API</PageTitle>

    <header class="sticky top-0 z-50 flex items-center justify-between gap-4 border-b border-base-200 bg-base-50/80 px-5 py-3.5 backdrop-blur-md sm:px-10 lg:px-14">
        <div class="flex items-center gap-3 font-semibold tracking-tight">
            <span class="relative h-[26px] w-[26px] flex-none rounded-[7px] bg-base-900">
                <span class="absolute bottom-[5px] right-[5px] h-2 w-2 rounded-sm bg-primary-600"></span>
            </span>
            Ashcroft
            <span class="rounded-md border border-base-200 px-1.5 py-1 font-mono text-xs font-medium leading-none text-base-400">v@(LibVersion)</span>
        </div>
        <a class="inline-flex items-center gap-2 rounded-lg border border-base-300 bg-white px-3.5 py-2 text-sm font-medium text-base-800 transition-colors hover:border-base-900"
           href="https://github.com/usepennington/ashcroft" target="_blank" rel="noopener">
            <svg class="h-4 w-4" viewBox="0 0 16 16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            GitHub
        </a>
    </header>

    <div class="mx-auto max-w-7xl px-5 sm:px-10 lg:px-14">
        <main class="min-w-0 pb-28">
            <section class="pb-7 pt-20">
                <h1 class="m-0 text-5xl font-semibold leading-none tracking-tight sm:text-6xl">Ashcroft</h1>
                <p class="mt-4 text-lg leading-normal text-base-500 sm:text-xl">
                    Generate Open&nbsp;Graph images, X cards, and blog headers from C#.
                    Set a background, describe content, pin it to an anchor, save.
                    Typography, wrapping, and legibility are computed; nothing is positioned by pixel.
                </p>
                <div class="mt-8 flex max-w-md items-stretch overflow-hidden rounded-[10px] border border-base-300 bg-white">
                    <span class="self-center pl-4 font-mono text-sm font-medium text-base-400">$</span>
                    <code class="flex-1 overflow-x-auto whitespace-nowrap px-3 py-3 font-mono text-sm font-medium">dotnet add package Ashcroft</code>
                    <button id="install-copy" type="button"
                            class="cursor-pointer border-l border-base-200 bg-base-100 px-4 text-sm font-medium text-base-500 transition-colors hover:bg-primary-50 hover:text-primary-700">Copy</button>
                </div>
                <p class="mt-3.5 text-sm text-base-400">.NET 10 · SkiaSharp + HarfBuzz · renders to PNG · MIT</p>
            </section>

            <article class="prose max-w-none">
                @((MarkupString)_page.Content.Html)
            </article>

            <footer class="mt-16 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-base-200 pt-10 text-sm text-base-400">
                <span>Ashcroft</span>
                <span class="text-base-300">·</span>
                <span>MIT licensed</span>
                <span class="text-base-300">·</span>
                <a class="text-primary-600 hover:text-primary-800" href="https://github.com/usepennington/ashcroft" target="_blank" rel="noopener">github.com/usepennington/ashcroft</a>
                <span class="text-base-300">·</span>
                <span>built with Pennington</span>
            </footer>
        </main>
    </div>
}

@code {
    // MinVer stamps the library's informational version at build time (Release only; Debug
    // builds carry the 1.0.0 default). Strip the "+<sha>" build metadata for display.
    private static readonly string LibVersion = GetLibVersion();

    private static string GetLibVersion()
    {
        var info = typeof(Ashcroft.CardBuilder).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
            .InformationalVersion ?? "1.0.0";
        var plus = info.IndexOf('+');
        return plus >= 0 ? info[..plus] : info;
    }

    [Parameter] public string? Path { get; set; }
    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    private RenderedItem? _page;
    private string _title = "Ashcroft";

    protected override async Task OnInitializedAsync()
    {
        var requested = new UrlPath(Path ?? string.Empty).EnsureLeadingSlash();
        _page = await Resolver.ResolveAsync(requested);

        if (_page is null)
        {
            if (HttpContext is not null) HttpContext.Response.StatusCode = 404;
            return;
        }

        if (_page.Metadata is DocFrontMatter fm && !string.IsNullOrWhiteSpace(fm.Title))
        {
            _title = fm.Title;
        }
    }
}
